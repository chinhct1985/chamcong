generator client {
  provider      = "prisma-client-js"
  // WSL + repo trên /mnt/d: dùng engine theo môi trường chạy `prisma generate` (Linux),
  // tránh ghi/đổi tên query_engine-windows.dll bị EPERM (file bị khoá trên ổ Windows).
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model EmployeeType {
  id        String   @id @default(cuid())
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]

  @@index([sortOrder])
}

model User {
  id           String             @id @default(cuid())
  fullName     String
  phone        String             @unique
  passwordHash String
  isActive     Boolean            @default(true)
  isManager    Boolean            @default(false)
  employeeTypeId String?
  employeeType   EmployeeType?    @relation(fields: [employeeTypeId], references: [id], onDelete: Restrict)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime              @updatedAt
  entries      AttendanceEntry[]
  submitLogs   AttendanceSubmitLog[]

  @@index([employeeTypeId])
}

model DropdownOption {
  id        String             @id @default(cuid())
  /// Mã ngắn dùng trong báo cáo / bảng chấm (admin chỉnh sửa)
  label     String
  /// Tên loại CC hiển thị trên form chấm công
  name      String
  sortOrder Int                @default(0)
  isActive  Boolean            @default(true)
  createdAt DateTime           @default(now())
  entries   AttendanceEntry[]
}

/// Ngày nghỉ lễ do admin cấu hình; dùng khi xuất Excel (cột "L", nền vàng) và công thức HC.
model PublicHoliday {
  id     String   @id @default(cuid())
  date   DateTime @db.Date
  name   String? /// Gợi nhớ, ví dụ: Tết Dương lịch
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date])
  @@index([date])
}

model AttendanceEntry {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  date       DateTime         @db.Date
  optionId   String
  option     DropdownOption   @relation(fields: [optionId], references: [id], onDelete: Restrict)
  /// Khi gửi 2 loại cùng lúc: "/2" — hiển thị: option.label + codeSuffix
  codeSuffix String?
  /// 0 = loại thứ nhất (combobox 1), 1 = loại thứ hai; dùng khi 2 bản ghi cùng ngày.
  optionSlot Int              @default(0)
  createdAt  DateTime         @default(now())

  @@unique([userId, date, optionId])
  @@index([userId, date])
}

/// Log câu mô tả mỗi lần nhân viên gửi chấm công thành công (theo từng ngày trong batch).
model AttendanceSubmitLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Nội dung hiển thị, ví dụ: "Ngày 01/04/2026 Nguyễn Văn A đã khai báo P vào lúc 14:30:00"
  message   String
  /// Ngày chấm tương ứng (lọc/báo cáo)
  date      DateTime @db.Date
  createdAt DateTime @default(now())

  @@index([userId, date])
  @@index([createdAt])
}
