JWT_SECRET=your_secret_key_change_in_production
# Docker (mặc định)
DATABASE_URL=postgresql://user:password@127.0.0.1:3041/chamcong
# Supabase — Direct: Settings → Database → Direct connection + URI
#   postgresql://postgres:PASSWORD@db.xxxxx.supabase.co:5432/postgres?sslmode=require
# Supabase — Transaction pooler: copy URI; user dạng postgres.xxx, port 6543, thêm ?pgbouncer=true
# Chỉ nạp lại 21 mã Loại CC (xóa lịch sử chấm công, giữ user): npm run db:apply-loai-cc
# Sau khi `docker compose restart db`, nếu gặp Prisma P1017 — chỉ cần tải lại trang
# (app đã retry kết nối); hoặc restart `npm run dev`.

# --- Domain / HTTPS (ví dụ https://chamcong.chinhct.com → localhost:3040) ---
#
# 1) BẮT BUỘC với `npm run dev` + domain/tunnel: hostname công khai (allowedDevOrigins + Server Action CSRF).
#    ALLOWED_DEV_ORIGINS=chamcong.chinhct.com,*.chinhct.com
#
#    (Tuỳ chọn) Chỉ bổ sung cho Server Actions, tách khời ALLOWED_DEV_ORIGINS:
#    SERVER_ACTIONS_ALLOWED_ORIGINS=chamcong.chinhct.com,*.chinhct.com
#
#    Hoặc cấu hình tunnel/nginx gửi: X-Forwarded-Host + X-Forwarded-Proto (mẫu: configs/reverse-proxy.example.conf).
#
# 2) HTTPS công khai: proxy (nginx / Cloudflare) phải gửi tới Node:
#    X-Forwarded-Proto: https
#    X-Forwarded-Host: chamcong.chinhct.com   (hoặc Host đúng subdomain)
#    Cloudflare Tunnel thường có header cf-visitor — app đã đọc thêm.
#
# 3) Cookie phiên trên HTTPS: bật (khuyến nghị khi user chỉ vào bằng https://)
#    COOKIE_SECURE=true
#
# 4) DATABASE_URL trên server thật: host Postgres phải truy cập được từ máy chạy Node (không dùng localhost nếu DB ở chỗ khác).
#
# Mẫu nginx: configs/reverse-proxy.example.conf
#
# Kiểm tra header khi mở bằng domain (chạy `next dev` rồi):
#   PUBLIC_APP_URL=https://chamcong.chinhct.com npm run check:domain
# Hoặc mở trình duyệt: /api/dev/request-headers (chỉ development)
